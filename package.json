{
  "name": "stream-schedule-bot",
  "version": "1.0.0",
  "description": "Discord bot that automates weekly stream schedule posting",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy-commands": "tsx src/commands/deploy-commands.ts"
  },
  "keywords": ["discord", "bot", "stream", "schedule"],
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "fast-check": "^3.22.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
